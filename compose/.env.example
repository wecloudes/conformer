# Copy to .env and adjust.

# --- auth ---------------------------------------------------------------------
# "static" (default, no Keycloak) or "keycloak".
AUTH_MODE=static

# Static bearer tokens -> entitled framework storage paths.
# Format: token=fw1,fw2;token2=fw3   (frameworks are storage paths)
STATIC_TOKENS=dev-token-changeme=cis_v600,iso27001,soc2

# Registry host suffix. Subdomain before it = framework (cis.<DOMAIN>).
DOMAIN=conformer.local

# --- dynamic patching ---------------------------------------------------------
# true: any module requested is fetched from UPSTREAM_REGISTRY and patched on
# demand (cached after first build). false: only pre-built modules are served.
DYNAMIC_BUILD=true
UPSTREAM_REGISTRY=registry.terraform.io
# Restrict which upstream modules may be dynamically pulled+patched. Comma-
# separated <namespace>/<name> globs. Empty = allow any. Example:
#   ALLOWED_MODULES=terraform-aws-modules/*,Azure/avm-res-*
ALLOWED_MODULES=
# Hard-fail a build when gitleaks finds secrets. false (default) reports only —
# third-party modules trip on example fixtures (examples/*.pfx, sample
# passwords). Set true for curated first-party modules.
GITLEAKS_STRICT=false

# --- minio --------------------------------------------------------------------
MINIO_ROOT_USER=minio-admin
MINIO_ROOT_PASSWORD=minio-secret

# --- keycloak (only when AUTH_MODE=keycloak, --profile keycloak) --------------
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_ISSUER=https://auth.conformer.local/realms/compliance
KEYCLOAK_JWKS_URL=https://auth.conformer.local/realms/compliance/protocol/openid-connect/certs
