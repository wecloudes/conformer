# Copy to .env and adjust.

# --- auth ---------------------------------------------------------------------
# "static" (default, no Keycloak) or "keycloak".
AUTH_MODE=static

# Static bearer tokens -> entitled framework storage paths.
# Format: token=fw1,fw2;token2=fw3   (frameworks are storage paths)
STATIC_TOKENS=dev-token-changeme=cis_v600,iso27001,soc2

# Registry host suffix. Subdomain before it = framework (cis.<DOMAIN>).
DOMAIN=conformer.local

# --- dynamic patching ---------------------------------------------------------
# true: any module requested is fetched from UPSTREAM_REGISTRY and patched on
# demand (cached after first build). false: only pre-built modules are served.
DYNAMIC_BUILD=true
UPSTREAM_REGISTRY=registry.terraform.io
# Restrict which upstream modules may be dynamically pulled+patched. Comma-
# separated <namespace>/<name> globs. Empty = allow any. Example:
#   ALLOWED_MODULES=terraform-aws-modules/*,Azure/avm-res-*
ALLOWED_MODULES=
# Hard-fail a build when gitleaks finds secrets. false (default) reports only —
# third-party modules trip on example fixtures (examples/*.pfx, sample
# passwords). Set true for curated first-party modules.
GITLEAKS_STRICT=false

# --- S3 storage (versitygw) ---------------------------------------------------
# Root credentials for the versitygw S3 gateway (and the registry-api S3 client).
S3_ROOT_USER=conformer
S3_ROOT_PASSWORD=conformer-secret
# Endpoint used to SIGN presigned download URLs — must be reachable by the
# Terraform consumer (not the internal versitygw:7070). Defaults to
# localhost:7070 (versitygw's published port). Use a public host if consumers
# are remote; the S3 signature binds the host, so it must match where the
# consumer connects.
S3_PUBLIC_ENDPOINT=localhost:7070
S3_PUBLIC_USE_SSL=false

# --- private / VPN-only access (optional) -------------------------------------
# Restrict the registry to a VPN. BIND_IP is the host interface the published
# ports (Caddy 80/443, versitygw 7070) bind to. Default 0.0.0.0 = public. Set it
# to your VPN interface IP (e.g. the WireGuard wg0 address 10.13.13.1) so the
# registry is reachable ONLY by VPN peers; the only public port is then
# WireGuard's 51820/udp on the host. Full guide: docs/07-private-vpn-access.md.
# BIND_IP=10.13.13.1
# When BIND_IP is a VPN address, presigned download URLs must also use a
# VPN-reachable host (the S3 signature binds it):
# S3_PUBLIC_ENDPOINT=10.13.13.1:7070

# --- external OIDC (optional) -------------------------------------------------
# This stack ships static-token auth. To use OIDC instead, run your own Keycloak
# (or any OIDC IdP), set AUTH_MODE=keycloak above, and point these at it.
# KEYCLOAK_ISSUER=https://auth.example.com/realms/compliance
# KEYCLOAK_JWKS_URL=https://auth.example.com/realms/compliance/protocol/openid-connect/certs
